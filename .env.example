# Discord webhook (uu tien URL day du)
DISCORD_WEBHOOK_URL= https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN

# Hoac dung ID + TOKEN (neu de trong URL, code se tu ghep)
DISCORD_WEBHOOK_ID= WEBHOOK_ID
DISCORD_WEBHOOK_TOKEN= WEBHOOK_TOKEN

# Nguong chung (neu khong set CPU/RAM rieng thi dung gia tri nay cho ca hai)
# REPORT_THRESHOLD_PERCENT=80
# Tuy chon: nguong rieng (bo qua thi lay tu REPORT_THRESHOLD_PERCENT)
REPORT_THRESHOLD_CPU_PERCENT=85
REPORT_THRESHOLD_RAM_PERCENT=75

# So dong top CPU / top RAM trong log va Discord (mac dinh 2 trong code neu khong set)
TOP_REPORT_PROCESS_COUNT=5

# Chu ky: sleep sau moi vong do (giay). Ten thay the: MONITOR_INTERVAL_SECONDS
CHECK_INTERVAL_SECONDS=5

# Thoi gian do CPU tong (psutil interval), va thoi gian lay mau CPU theo process
CPU_MEASURE_INTERVAL_SECONDS=1
PROCESS_SAMPLE_SECONDS=0.2

ENABLE_DISCORD_ALERT=true
ALERT_MODE=smart
ALERT_COOLDOWN_SECONDS=60
ALERT_DELTA_PERCENT=5