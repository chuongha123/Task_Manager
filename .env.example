REPORT_THRESHOLD_PERCENT=50
TOP_REPORT_PROCESS_COUNT=5
ENABLE_DISCORD_ALERT=true
ALERT_MODE=smart
ALERT_COOLDOWN_SECONDS=60
ALERT_DELTA_PERCENT=5