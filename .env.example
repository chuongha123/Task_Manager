# Discord webhook (uu tien URL day du)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN

# Hoac dung ID + TOKEN (neu de trong URL, code se tu ghep)
DISCORD_WEBHOOK_ID=
